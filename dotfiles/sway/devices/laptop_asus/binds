bindsym XF86KbdBrightnessDown exec ~/myconfig/scripts/myasus kbd-backlight-down
bindsym XF86KbdBrightnessUp exec ~/myconfig/scripts/myasus kbd-backlight-up
bindsym XF86MonBrightnessDown exec light -U 10
bindsym XF86MonBrightnessUp exec light -A 10
bindsym XF86Launch1 exec ~/myconfig/scripts/myasus rog-toggle
bindsym XF86Launch3 exec asusctl aura effect --next-mode
bindsym XF86Launch4 exec ~/myconfig/scripts/myasus profile-next
bindsym XF86TouchpadToggle exec swaymsg input 2362:12305:ASUP1208:00_093A:3011_Touchpad events toggle
